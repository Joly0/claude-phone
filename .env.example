# ====================================
# Claude Phone Configuration
# ====================================
# Copy this to .env and fill in your values

# ====================================
# Network Configuration
# ====================================

# Your server's LAN IP (CRITICAL for RTP audio)
# This IP goes into SDP packets so 3CX knows where to send audio
EXTERNAL_IP=10.0.0.100

# Public IP to advertise in SIP contact headers and SDP.
# Only needed when the server sits behind NAT and registers directly with an
# external SIP trunk, so that signaling and RTP are reachable from outside.
# Defaults to EXTERNAL_IP when unset.
# Set to "auto" for dynamic IP connections: the current public IP is detected
# at startup and re-checked periodically; on a change the app re-registers SIP
# and refreshes the FreeSWITCH advertised RTP address automatically.
# PUBLIC_IP=203.0.113.10
# PUBLIC_IP=auto

# How often to re-check the public IP in auto mode, in seconds
# PUBLIC_IP_CHECK_INTERVAL=300

# SIP bind address for drachtio. Defaults to EXTERNAL_IP. Binding a specific
# address avoids startup failures on hosts where the same IP exists on more
# than one interface (e.g. Unraid with "Host access to custom networks").
# Set to * to bind all interfaces.
# DRACHTIO_BIND_IP=*

# ====================================
# Drachtio Configuration
# ====================================

DRACHTIO_HOST=127.0.0.1
DRACHTIO_PORT=9022
DRACHTIO_SECRET=cymru

# SIP port for Contact header (5070 for 3CX SBC mode, 5060 for direct registration)
# This MUST match the port in docker-compose.yml drachtio command
DRACHTIO_SIP_PORT=5060

# SIP TLS port for drachtio's TLS listener
# Change it if another service on the host already uses 5061
# DRACHTIO_TLS_PORT=5061

# ====================================
# FreeSWITCH Configuration
# ====================================

FREESWITCH_HOST=127.0.0.1
FREESWITCH_PORT=8021
FREESWITCH_SECRET=JambonzR0ck$

# ====================================
# 3CX / SIP Configuration
# ====================================

# Your SIP server hostname or IP
SIP_DOMAIN=your-3cx-server.3cx.us
SIP_REGISTRAR=10.0.0.50

# SIP transport: udp, tcp, or tls (default: udp)
# Use tls for SIP trunk providers that only accept registration over TLS (port 5061)
SIP_TRANSPORT=udp

# DNS server for SRV record resolution
# Some SIP trunk providers publish SRV records that only resolve through the
# local router's DNS, not through public resolvers. Set this to your router's
# IP if SIP registration fails with the default DNS.
# DNS_SERVER=192.168.1.1

# Default extension for outbound calls
SIP_EXTENSION=9000
SIP_AUTH_ID=your-auth-id
SIP_PASSWORD=your-password

# Default caller ID for outbound PSTN calls
DEFAULT_CALLER_ID=+15551234567

# ====================================
# Voice Provider Selection
# ====================================

# Global default voice provider: gemini | openai | classic
# Can be overridden per extension via the "provider" field in
# voice-app/config/devices.json
VOICE_PROVIDER=gemini

# ====================================
# Google Gemini (STT & TTS)
# ====================================

GOOGLE_API_KEY=your-google-api-key

# Default TTS voice (Kore, Puck, Charon, Fenrir, Aoede, Leda, Orus, Zephyr)
GOOGLE_TTS_VOICE=Kore

# Override the Gemini Live model (optional)
# GEMINI_LIVE_MODEL=models/gemini-3.1-flash-live-preview

# ====================================
# OpenAI Realtime (VOICE_PROVIDER=openai)
# ====================================

# OPENAI_API_KEY=your-openai-api-key

# Realtime model; switch to gpt-live-1 once OpenAI opens it up on the API
# OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Voice (marin, cedar, alloy, ash, ballad, coral, echo, sage, shimmer, verse)
# OPENAI_REALTIME_VOICE=marin

# Input transcription model
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# OpenClaw routing credentials are configured in voice-app/config/openclaw.json
# See voice-app/config/openclaw.json.example for the format

# ====================================
# Application Settings
# ====================================

# HTTP server port for API and audio file serving
HTTP_PORT=3000

# WebSocket port for audio streaming from FreeSWITCH
WS_PORT=3001

# Audio files directory
AUDIO_DIR=/app/audio

# ====================================
# Outbound Call Settings
# ====================================

# Maximum conversation turns for outbound calls
MAX_CONVERSATION_TURNS=10

# Ring timeout in seconds
OUTBOUND_RING_TIMEOUT=30

# ====================================
# Optional: Debug
# ====================================

# DEBUG=voice-app:*
